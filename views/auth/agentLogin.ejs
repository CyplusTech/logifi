<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Agent Portal — Sign In</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --white:        #ffffff;
      --page-bg:      #f5f6f8;
      --surface:      #ffffff;
      --border:       #e2e5ea;
      --border-focus: #3b6fe8;
      --text-primary: #1a1d23;
      --text-secondary:#6b7280;
      --text-hint:    #9ca3af;
      --accent:       #3b6fe8;
      --accent-dark:  #2d5bd4;
      --accent-light: #eef2fd;
      --danger:       #dc3545;
      --danger-bg:    #fff5f5;
      --success:      #16a34a;
      --shadow-card:  0 1px 3px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.07);
      --shadow-btn:   0 1px 4px rgba(59,111,232,.35);
      --radius-sm:    6px;
      --radius-md:    10px;
      --radius-lg:    16px;
      --font:         'Inter', system-ui, sans-serif;
      --t:            .18s ease;
    }

    html, body { height: 100%; font-family: var(--font); background: var(--page-bg); color: var(--text-primary); -webkit-font-smoothing: antialiased; }

    /* Layout */
    .page { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 1.5rem 1rem 2rem; }

    /* Brand */
    .brand { display: flex; align-items: center; gap: 10px; margin-bottom: 1.75rem; text-decoration: none; }
    .brand-icon { width: 38px; height: 38px; background: var(--accent); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .brand-icon svg { display: block; }
    .brand-name { font-size: 18px; font-weight: 600; color: var(--text-primary); letter-spacing: -.3px; }
    .brand-name span { color: var(--accent); }

    /* Card */
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); box-shadow: var(--shadow-card); width: 100%; max-width: 420px; padding: 2rem 2rem 1.75rem; }
    .card-header { margin-bottom: 1.75rem; }
    .card-title { font-size: 20px; font-weight: 600; color: var(--text-primary); letter-spacing: -.3px; margin-bottom: 4px; }
    .card-sub { font-size: 13.5px; color: var(--text-secondary); }

    /* Alert */
    .alert { display: none; align-items: flex-start; gap: 10px; background: var(--danger-bg); border: 1px solid #fecaca; border-radius: var(--radius-sm); padding: .65rem .875rem; margin-bottom: 1.25rem; font-size: 13.5px; color: var(--danger); }
    .alert.visible { display: flex; }
    .alert.info { background: #f0fdf4; border-color: #bbf7d0; color: #166534; }
    .alert-icon { flex-shrink: 0; margin-top: 1px; }

    /* Form */
    .form { display: flex; flex-direction: column; gap: 1rem; }
    .field { display: flex; flex-direction: column; gap: 5px; }
    .field-label { font-size: 13px; font-weight: 500; color: var(--text-primary); }
    .field-label .req { color: var(--accent); margin-left: 2px; }
    .input-wrap { position: relative; display: flex; align-items: center; }
    .input-icon { position: absolute; left: 12px; color: var(--text-hint); pointer-events: none; display: flex; }
    .input-toggle { position: absolute; right: 12px; background: none; border: none; cursor: pointer; color: var(--text-hint); display: flex; padding: 4px; border-radius: 4px; transition: color var(--t); }
    .input-toggle:hover { color: var(--text-secondary); }

    input[type="text"],
    input[type="email"],
    input[type="password"] { width: 100%; height: 42px; padding: 0 12px 0 38px; border: 1px solid var(--border); border-radius: var(--radius-sm); font-size: 14px; font-family: var(--font); color: var(--text-primary); background: var(--white); outline: none; transition: border-color var(--t), box-shadow var(--t); -webkit-appearance: none; }
    input[type="password"].has-toggle { padding-right: 42px; }
    input:focus { border-color: var(--border-focus); box-shadow: 0 0 0 3px rgba(59,111,232,.12); }
    input.invalid { border-color: var(--danger); box-shadow: 0 0 0 3px rgba(220,53,69,.10); }

    .field-error { font-size: 12px; color: var(--danger); min-height: 16px; }

    /* Row */
    .row { display: flex; align-items: center; justify-content: space-between; gap: .5rem; flex-wrap: wrap; }
    .check-label { display: flex; align-items: center; gap: 7px; font-size: 13.5px; color: var(--text-secondary); cursor: pointer; user-select: none; }
    .check-label input[type="checkbox"] { width: 16px; height: 16px; padding: 0; accent-color: var(--accent); cursor: pointer; flex-shrink: 0; }
    .link { font-size: 13.5px; color: var(--accent); text-decoration: none; font-weight: 500; }
    .link:hover { text-decoration: underline; }

    /* Submit */
    .btn-submit { width: 100%; height: 44px; background: var(--accent); color: #fff; border: none; border-radius: var(--radius-sm); font-size: 14.5px; font-weight: 600; font-family: var(--font); cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; box-shadow: var(--shadow-btn); transition: background var(--t), transform var(--t), opacity var(--t); margin-top: .25rem; }
    .btn-submit:hover { background: var(--accent-dark); }
    .btn-submit:active { transform: scale(.98); }
    .btn-submit:disabled { opacity: .65; cursor: not-allowed; transform: none; }

    .spinner { width: 17px; height: 17px; border: 2.5px solid rgba(255,255,255,.35); border-top-color: #fff; border-radius: 50%; animation: spin .7s linear infinite; display: none; }
    .btn-submit.loading .spinner { display: block; }
    .btn-submit.loading .btn-text { display: none; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Divider */
    .divider { display: none; align-items: center; gap: 12px; margin: 1.25rem 0; color: var(--text-hint); font-size: 12px; }
    .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

    /* SSO */
    .btn-sso { width: 100%; display: none !important; height: 42px; background: var(--white); color: var(--text-primary); border: 1px solid var(--border); border-radius: var(--radius-sm); font-size: 13.5px; font-weight: 500; font-family: var(--font); cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: background var(--t), border-color var(--t); }
    .btn-sso:hover { background: var(--page-bg); border-color: #c6cad2; }

    /* Footer */
    .card-footer { margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid var(--border); text-align: center; }
    .footer-text { font-size: 13px; color: var(--text-secondary); }

    /* Security badge */
    .security { margin-top: 1.25rem; display: flex; align-items: center; justify-content: center; gap: 6px; font-size: 12px; color: var(--text-hint); }

    /* Success */
    .success-overlay { display: none; flex-direction: column; align-items: center; justify-content: center; gap: 12px; padding: 2rem 0 1rem; text-align: center; }
    .success-overlay.visible { display: flex; }
    .success-circle { width: 58px; height: 58px; border-radius: 50%; background: #edfdf4; border: 2px solid #bbf7d0; display: flex; align-items: center; justify-content: center; color: var(--success); }
    .success-title { font-size: 16px; font-weight: 600; color: var(--text-primary); }
    .success-sub { font-size: 13.5px; color: var(--text-secondary); }

    /* Responsive */
    @media (max-width: 480px) {
      .page { justify-content: flex-start; padding-top: 2.5rem; }
      .card { padding: 1.5rem 1.25rem; border-radius: var(--radius-md); box-shadow: none; border-color: transparent; background: var(--white); }
    }
    @media (min-width: 768px) {
      .card { padding: 2.25rem 2.5rem 2rem; }
    }
    @media (prefers-reduced-motion: reduce) {
      .spinner { animation: none; }
      * { transition: none !important; }
    }
  </style>
</head>
<body>
<main class="page">

  <a href="#" class="brand" aria-label="Agent Portal home">
    <div class="brand-icon" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <circle cx="10" cy="7" r="3.5" stroke="#fff" stroke-width="1.6"/>
        <path d="M3 17c0-3.314 3.134-6 7-6s7 2.686 7 6" stroke="#fff" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
    </div>
    <span class="brand-name">Agent<span>Portal</span></span>
  </a>

  <div class="card" role="main">
    <div class="card-header">
      <h1 class="card-title">Sign in to your account</h1>
      <p class="card-sub">Enter your credentials to access the dashboard.</p>
    </div>

    <div class="alert" id="alert" role="alert" aria-live="polite">
      <span class="alert-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M8 5v3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="8" cy="11" r=".75" fill="currentColor"/></svg>
      </span>
      <span id="alert-msg"></span>
    </div>

    <form class="form" id="loginForm" novalidate autocomplete="on">

      <div class="field">
        <label class="field-label" for="email">Email address <span class="req" aria-hidden="true">*</span></label>
        <div class="input-wrap">
          <span class="input-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1.5" y="3.5" width="13" height="9" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M1.5 5.5 8 9.5l6.5-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
          </span>
          <input type="email" id="email" name="email" placeholder="you@company.com" autocomplete="email" inputmode="email" required />
        </div>
        <span class="field-error" id="email-error" aria-live="polite"></span>
      </div>

      <div class="field">
        <label class="field-label" for="password">Password <span class="req" aria-hidden="true">*</span></label>
        <div class="input-wrap">
          <span class="input-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="3" y="7" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M5 7V5a3 3 0 0 1 6 0v2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
          </span>
          <input class="has-toggle" type="password" id="password" name="password" placeholder="••••••••" autocomplete="current-password" required />
          <button type="button" class="input-toggle" id="togglePwd" aria-label="Show password" aria-pressed="false">
            <svg id="eyeIcon" width="17" height="17" viewBox="0 0 17 17" fill="none"><path d="M1 8.5S3.7 3 8.5 3 16 8.5 16 8.5 13.3 14 8.5 14 1 8.5 1 8.5Z" stroke="currentColor" stroke-width="1.3"/><circle cx="8.5" cy="8.5" r="2.2" stroke="currentColor" stroke-width="1.3"/></svg>
            <svg id="eyeOffIcon" width="17" height="17" viewBox="0 0 17 17" fill="none" style="display:none"><path d="M2 2l13 13M7.1 4.2A7.2 7.2 0 0 1 8.5 4C13.3 4 16 9 16 9a11.5 11.5 0 0 1-1.9 2.5M9.8 12.7A5.5 5.5 0 0 1 8.5 13C3.7 13 1 8 1 8a11.5 11.5 0 0 1 2.5-3.3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
          </button>
        </div>
        <span class="field-error" id="pwd-error" aria-live="polite"></span>
      </div>

      <div class="row">
        <label class="check-label">
          <input type="checkbox" id="remember" name="remember" />
          Keep me signed in
        </label>
        <a href="#" class="link" id="forgotLink">Forgot password?</a>
      </div>

      <button type="submit" class="btn-submit" id="submitBtn">
        <span class="btn-text">Sign in</span>
        <span class="spinner" aria-hidden="true"></span>
      </button>
    </form>

    <div class="divider" id="divider">or continue with</div>
    <button type="button" class="btn-sso" id="ssoBtn">
      <svg width="17" height="17" viewBox="0 0 17 17" fill="none" aria-hidden="true"><rect x="1.5" y="1.5" width="6" height="6" rx="1" fill="#4285F4"/><rect x="9.5" y="1.5" width="6" height="6" rx="1" fill="#EA4335"/><rect x="1.5" y="9.5" width="6" height="6" rx="1" fill="#34A853"/><rect x="9.5" y="9.5" width="6" height="6" rx="1" fill="#FBBC05"/></svg>
      Sign in with Google SSO
    </button>

        <div class="card-footer" id="cardFooter">
        <p class="footer-text">
            Don't have an account?
            <a
            href="https://wa.me/2348027769825?text=Hello%20Logifi%20Support,%20I%20need%20help%20creating%20an%20account."
            target="_blank"
            class="link"
            >
            Contact your administrator.
            </a>
        </p>
        </div>

    <div class="success-overlay" id="successOverlay" aria-live="polite">
      <div class="success-circle" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 26 26" fill="none"><path d="M6 13l5 5 9-9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <p class="success-title">You're signed in!</p>
      <p class="success-sub">Redirecting to your dashboard…</p>
    </div>
  </div>

  <div class="security">
    <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true"><path d="M6.5 1 2 3v3.5c0 2.8 1.9 5.3 4.5 6 2.6-.7 4.5-3.2 4.5-6V3L6.5 1Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
    256-bit SSL — your connection is secure
  </div>

</main>

<script>
(function () {
  const form      = document.getElementById('loginForm');
  const emailEl   = document.getElementById('email');
  const pwdEl     = document.getElementById('password');
  const submitBtn = document.getElementById('submitBtn');
  const alertEl   = document.getElementById('alert');
  const alertMsg  = document.getElementById('alert-msg');
  const emailErr  = document.getElementById('email-error');
  const pwdErr    = document.getElementById('pwd-error');
  const toggleBtn = document.getElementById('togglePwd');
  const eyeIcon   = document.getElementById('eyeIcon');
  const eyeOff    = document.getElementById('eyeOffIcon');
  const success   = document.getElementById('successOverlay');
  const forgotLink= document.getElementById('forgotLink');
  const ssoBtn    = document.getElementById('ssoBtn');

  function isEmail(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim()); }

  function setError(input, errEl, msg) {
    errEl.textContent = msg;
    input.classList.toggle('invalid', !!msg);
    input.setAttribute('aria-invalid', String(!!msg));
  }

  function clearErrors() {
    setError(emailEl, emailErr, '');
    setError(pwdEl, pwdErr, '');
    alertEl.className = 'alert';
  }

  function showAlert(msg, type) {
    alertMsg.textContent = msg;
    alertEl.className = 'alert visible' + (type === 'info' ? ' info' : '');
    alertEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  emailEl.addEventListener('blur', () => {
    if (emailEl.value && !isEmail(emailEl.value)) setError(emailEl, emailErr, 'Enter a valid email address.');
    else setError(emailEl, emailErr, '');
  });
  emailEl.addEventListener('input', () => { if (emailEl.classList.contains('invalid') && isEmail(emailEl.value)) setError(emailEl, emailErr, ''); });
  pwdEl.addEventListener('input', () => { if (pwdEl.classList.contains('invalid') && pwdEl.value.length >= 6) setError(pwdEl, pwdErr, ''); });

  toggleBtn.addEventListener('click', () => {
    const show = pwdEl.type === 'password';
    pwdEl.type = show ? 'text' : 'password';
    eyeIcon.style.display = show ? 'none' : '';
    eyeOff.style.display  = show ? '' : 'none';
    toggleBtn.setAttribute('aria-pressed', String(show));
    toggleBtn.setAttribute('aria-label', show ? 'Hide password' : 'Show password');
    pwdEl.focus();
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearErrors();
    let valid = true;
    const email = emailEl.value.trim();
    const pwd   = pwdEl.value;

    if (!email) { setError(emailEl, emailErr, 'Email is required.'); valid = false; }
    else if (!isEmail(email)) { setError(emailEl, emailErr, 'Enter a valid email address.'); valid = false; }
    if (!pwd) { setError(pwdEl, pwdErr, 'Password is required.'); valid = false; }
    else if (pwd.length < 6) { setError(pwdEl, pwdErr, 'Password must be at least 6 characters.'); valid = false; }
    if (!valid) return;

    submitBtn.disabled = true;
            submitBtn.classList.add('loading');

            try {
            const response = await fetch('/agent/login/auth', {
                method: 'POST',
                headers: {
                'Content-Type': 'application/json'
                },
                credentials: 'same-origin',
                body: JSON.stringify({
                email,
                password: pwd
                })
            });

            const data = await response.json();

            submitBtn.disabled = false;
            submitBtn.classList.remove('loading');

            if (data.success) {
                form.style.display = 'none';
                document.getElementById('cardFooter').style.display = 'none';
                document.getElementById('divider').style.display = 'none';
                ssoBtn.style.display = 'none';
                alertEl.className = 'alert';
                success.classList.add('visible');

                // Optional redirect
                if (data.redirect) {
                window.location.href = data.redirect;
                }

            } else {
                showAlert(data.message || 'Incorrect email or password.');
                pwdEl.value = '';
                pwdEl.focus();
            }

            } catch (err) {
            submitBtn.disabled = false;
            submitBtn.classList.remove('loading');
            showAlert('Server error. Please try again.');
            console.error(err);
            }
  });

            forgotLink.addEventListener('click', (e) => {
            e.preventDefault();

            const email = emailEl.value.trim();

            if (!email || !isEmail(email)) {
                emailEl.focus();
                setError(
                emailEl,
                emailErr,
                'Enter your email first before contacting support.'
                );
                return;
            }

            const supportNumber = "2348027769825"; // your support WhatsApp number

            const message = encodeURIComponent(
                `Hello Logifi Support,

            I forgot my password and need assistance resetting my account.

            Email: ${email}

            Thank you.`
            );

            window.open(
                `https://wa.me/${supportNumber}?text=${message}`,
                "_blank"
            );
            });

  ssoBtn.addEventListener('click', () => {
    ssoBtn.disabled = true;
    ssoBtn.textContent = 'Redirecting…';
    setTimeout(() => {
      ssoBtn.disabled = false;
      ssoBtn.innerHTML = '<svg width="17" height="17" viewBox="0 0 17 17" fill="none" aria-hidden="true"><rect x="1.5" y="1.5" width="6" height="6" rx="1" fill="#4285F4"/><rect x="9.5" y="1.5" width="6" height="6" rx="1" fill="#EA4335"/><rect x="1.5" y="9.5" width="6" height="6" rx="1" fill="#34A853"/><rect x="9.5" y="9.5" width="6" height="6" rx="1" fill="#FBBC05"/></svg> Sign in with Google SSO';
    }, 1800);
  });
})();
</script>
</body>
</html>